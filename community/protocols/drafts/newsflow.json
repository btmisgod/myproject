{
  "group_protocol": {
    "protocol_meta": {
      "protocol_id": "newsflow-group-protocol-debug-v1",
      "protocol_name": "Newsflow Group Protocol Debug Draft",
      "protocol_version": "0.1.0-draft",
      "status": "debug_draft",
      "source_of_truth": "group_protocol",
      "design_priority": "behavior_first_real_collaboration",
      "deployment_state": "requires_agent_id_binding_before_patch"
    },
    "channel": {
      "channel_type": "project"
    },
    "template_binding": {
      "required_before_patch": true,
      "notes": [
        "Replace every __ROLE_AGENT_ID__ placeholder with a real agent id before PATCH /groups/{id}/protocol.",
        "Current server gate authority still depends on real manager/worker agent id binding.",
        "This draft is intentionally a protocol template, not a directly runnable final binding."
      ],
      "placeholders": {
        "manager_agent_id": "__MANAGER_AGENT_ID__",
        "editor_agent_id": "__EDITOR_AGENT_ID__",
        "tester_agent_id": "__TESTER_AGENT_ID__",
        "worker_a_agent_id": "__WORKER_A_AGENT_ID__",
        "worker_b_agent_id": "__WORKER_B_AGENT_ID__"
      }
    },
    "members": {
      "all_agent_ids": [
        "__MANAGER_AGENT_ID__",
        "__EDITOR_AGENT_ID__",
        "__TESTER_AGENT_ID__",
        "__WORKER_A_AGENT_ID__",
        "__WORKER_B_AGENT_ID__"
      ],
      "manager_agent_id": "__MANAGER_AGENT_ID__",
      "worker_agent_ids": [
        "__EDITOR_AGENT_ID__",
        "__TESTER_AGENT_ID__",
        "__WORKER_A_AGENT_ID__",
        "__WORKER_B_AGENT_ID__"
      ],
      "role_rules": {
        "manager_holds_decision_authority_for_step_transition": true,
        "manager_has_acceptance_duty_for_every_stage": true,
        "tester_may_recommend_transition_but_must_route_via_manager": true,
        "server_formal_gate_role_collapses_non_manager_agents_to_worker_class": true,
        "stage_internal_peer_coordination_may_happen_directly": true,
        "cross_stage_control_must_route_via_manager": true,
        "human_plain_text_applies_next_cycle_only": true,
        "server_must_not_summarize_human_plain_text": true
      },
      "role_assignments": {
        "manager": {
          "agent_id": "__MANAGER_AGENT_ID__",
          "server_gate_role": "manager",
          "responsibility": "task decomposition, stage dispatch, stage acceptance, formal transition, retrospective, next-cycle optimization prompts"
        },
        "editor": {
          "agent_id": "__EDITOR_AGENT_ID__",
          "server_gate_role": "worker",
          "responsibility": "consume approved material, select, order, layout, publish product body without changing source facts"
        },
        "tester": {
          "agent_id": "__TESTER_AGENT_ID__",
          "server_gate_role": "worker",
          "responsibility": "review material and product, run real web search for product testing and benchmarking, recommend but not directly emit formal transition"
        },
        "worker_a": {
          "agent_id": "__WORKER_A_AGENT_ID__",
          "server_gate_role": "worker",
          "responsibility": "collect politics-economy and technology materials"
        },
        "worker_b": {
          "agent_id": "__WORKER_B_AGENT_ID__",
          "server_gate_role": "worker",
          "responsibility": "collect sports and entertainment materials"
        }
      }
    },
    "group_identity": {
      "group_type": "project",
      "workflow_mode": "long_running_multi_cycle_newsflow",
      "group_objective": "Run a long-lived Newsflow group that repeatedly produces a Chinese hot-news product through real multi-agent collaboration, review, retrospective, and optimization."
    },
    "workflow": {
      "debug_scope": {
        "current_server_stage_engine_scope": "linear manager-close progression only",
        "intra_stage_redo_and_partial_pass_handling": "kept inside the current stage until manager emits the formal close signal",
        "cycle_counter_limit_note": "cycle_number and cycle_id should be restated by manager artifacts during debug because the current server session engine does not yet auto-maintain a full cycle history projection"
      },
      "formal_workflow": {
        "workflow_id": "newsflow-workflow-debug-v1",
        "goal": "Produce a Chinese news product covering politics-economy, technology, sports, and entertainment. The real test target is not first-cycle quality but whether five agents can complete two cycles with real outputs and retrospective-driven improvement.",
        "design_principles": [
          "behavior_first_not_quality_first",
          "real_outputs_not_template_faking",
          "manager_decides_stage_goal_and_acceptance_detail_each_cycle",
          "control_layer_and_content_layer_are_separated",
          "server_controls_step_progression_only",
          "all_non_control_communication_should_remain_public_in_group"
        ],
        "human_input_rule": {
          "human_may_post_plain_text_anytime": true,
          "human_plain_text_is_not_direct_transition_authority": true,
          "human_plain_text_becomes_manager_input_at_next_cycle_start_only": true,
          "human_does_not_bypass_manager_to_manage_workers": true,
          "if_no_human_input_exists_cycle_still_runs": true
        },
        "cycle_start_inputs": {
          "always_include": [
            "task_goal_prompt_for_this_cycle"
          ],
          "carry_forward_when_available": [
            "previous_retrospective_summary",
            "previous_agent_optimization_prompts",
            "raw_human_plain_text_since_previous_cycle_start"
          ],
          "server_boundary": [
            "server stores or exposes raw eligible human text",
            "server does not summarize, interpret, or rewrite that text into a manager prompt"
          ]
        },
        "product_contract": {
          "language": "zh-CN",
          "sections": [
            "politics_economy",
            "technology",
            "sports",
            "entertainment"
          ],
          "target_items_per_section": 10,
          "main_push_requirement": "3 images + about 200 Chinese characters",
          "secondary_push_requirement": "1 image + about 100 Chinese characters",
          "general_push_requirement": "no image + about 50 Chinese characters",
          "news_time_window": "within last 24 hours",
          "final_delivery_shape": "one complete final message in the group"
        },
        "decision_model": {
          "intra_stage_correction_actions": [
            "partial_pass",
            "redo"
          ],
          "stage_closure_actions": [
            "proceed",
            "forced_proceed"
          ],
          "partial_pass_rule": "two unsuccessful partial-pass revisions escalate to redo inside the same stage",
          "redo_rule": "redo count above 2 inside the same stage escalates to forced_proceed",
          "forced_proceed_rule": "forced proceed closes the current stage without waiting for repair and must leave a risk note for retrospective",
          "server_transition_trigger": "only manager formal stage-close control messages advance the server stage"
        },
        "cycle_completion_definition": {
          "cycle_is_complete_when": "agent.optimization is formally closed by manager",
          "test_success_for_current_debug": "workflow completes two cycles with real outputs and correct stage behavior, even if early-cycle product quality is poor"
        },
        "threading_guidance": {
          "default_model": "one main thread per cycle",
          "stage_internal_replies_allowed": true,
          "related_message_id_should_pin_precise_artifact_relationships": true,
          "final_report_message_is_cycle_anchor": true
        },
        "stages": {
          "cycle.start": {
            "owner": "manager",
            "goal": "Generate the cycle task decomposition and define stage goals, acceptance focus, and handoff expectations for the current cycle.",
            "input": [
              "task_goal_prompt",
              "previous_retrospective_summary",
              "previous_agent_optimization_prompts",
              "human_plain_text_since_previous_cycle_start"
            ],
            "output": [
              "cycle_task_plan"
            ],
            "notes": [
              "Manager chooses decomposition granularity.",
              "Workflow should not hardcode detailed acceptance thresholds here.",
              "During debug the manager should explicitly state what counts as done for the next stage."
            ]
          },
          "material.collect": {
            "owner": "worker_a_and_worker_b_under_manager_dispatch",
            "goal": "Collect real news materials for all four sections using live web search.",
            "input": [
              "cycle_task_plan"
            ],
            "output": [
              "candidate_material_pool"
            ],
            "notes": [
              "Worker A handles politics-economy and technology.",
              "Worker B handles sports and entertainment.",
              "Tester may begin reviewing as materials arrive.",
              "Editor cannot consume until all four sections have material results available."
            ]
          },
          "material.review": {
            "owner": "tester_with_manager_closure",
            "goal": "Review candidate materials, leave evidence and recommendations, and let manager close the stage.",
            "input": [
              "candidate_material_pool"
            ],
            "output": [
              "material_review_feedback",
              "manager_stage_close_or_intra_stage_correction"
            ],
            "notes": [
              "Tester reviews with reasons and evidence.",
              "Partial pass and redo stay inside this stage until manager emits the formal close signal.",
              "There is no backtrack to a separate earlier workflow branch outside this stage."
            ]
          },
          "draft.compose": {
            "owner": "editor",
            "goal": "Compose the product draft from approved materials into the final product shape.",
            "input": [
              "approved_materials_or_forced_proceed_material_state"
            ],
            "output": [
              "product_draft"
            ],
            "notes": [
              "Editor may select, order, and lay out.",
              "Editor must not alter source facts.",
              "If materials are weak, the draft may still be weak and later be handled by proofread, forced proceed, and retrospective."
            ]
          },
          "draft.proofread": {
            "owner": "tester_with_manager_closure",
            "goal": "Review the product draft as a product, not as a fresh material collection task.",
            "input": [
              "product_draft"
            ],
            "output": [
              "proofread_feedback"
            ]
          },
          "draft.revise": {
            "owner": "editor",
            "goal": "Revise the draft according to current-stage feedback without reopening the material-collection phase.",
            "input": [
              "proofread_feedback_or_recheck_feedback"
            ],
            "output": [
              "revised_product_draft"
            ],
            "notes": [
              "No cross-stage rollback to material.collect.",
              "If the draft remains poor, manager may still later forced_proceed and record risk."
            ]
          },
          "draft.recheck": {
            "owner": "tester_with_manager_closure",
            "goal": "Recheck the revised draft and either support closure or keep correction inside the same stage loop.",
            "input": [
              "revised_product_draft"
            ],
            "output": [
              "recheck_feedback"
            ]
          },
          "publish.decision": {
            "owner": "manager",
            "goal": "Decide whether to release the current draft or forced_proceed it into release.",
            "input": [
              "latest_recheck_state",
              "current_risk_record"
            ],
            "output": [
              "publish_decision"
            ],
            "notes": [
              "This stage does not introduce a separate rollback branch.",
              "If the release gate keeps failing and thresholds are hit, manager should forced_proceed and record the risk."
            ]
          },
          "report.publish": {
            "owner": "editor_under_manager_release_decision",
            "goal": "Publish one complete final product message for the cycle.",
            "input": [
              "publish_decision"
            ],
            "output": [
              "final_product_message"
            ]
          },
          "product.test": {
            "owner": "tester",
            "goal": "Evaluate the already published product from a user-view perspective.",
            "input": [
              "final_product_message"
            ],
            "output": [
              "product_test_report"
            ],
            "notes": [
              "This stage does not reopen the current final draft for editing."
            ]
          },
          "product.benchmark": {
            "owner": "tester",
            "goal": "Use real web search to compare the published product against external comparable products.",
            "input": [
              "final_product_message",
              "live_web_search_results"
            ],
            "output": [
              "benchmark_report"
            ]
          },
          "product.cross_cycle_compare": {
            "owner": "tester",
            "goal": "Compare the published product against the previous cycle when available.",
            "input": [
              "final_product_message",
              "previous_cycle_artifacts_when_available"
            ],
            "output": [
              "cross_cycle_report"
            ],
            "notes": [
              "For cycle 1 the expected result is 'no historical comparison target'."
            ]
          },
          "retrospective.plan": {
            "owner": "manager",
            "goal": "Turn reports and execution evidence into a discussion agenda.",
            "input": [
              "product_test_report",
              "benchmark_report",
              "cross_cycle_report",
              "execution_evidence"
            ],
            "output": [
              "retrospective_plan"
            ]
          },
          "retrospective.discussion": {
            "owner": "manager_moderated_group_discussion",
            "goal": "Run an evidence-based discussion around the agenda.",
            "input": [
              "retrospective_plan"
            ],
            "output": [
              "discussion_record"
            ],
            "notes": [
              "Manager decides who needs to speak.",
              "Not every agent must speak in every cycle."
            ]
          },
          "retrospective.summary": {
            "owner": "manager",
            "goal": "Produce the formal retrospective summary and next-cycle requirements.",
            "input": [
              "discussion_record"
            ],
            "output": [
              "retrospective_summary"
            ]
          },
          "agent.optimization": {
            "owner": "manager",
            "goal": "Issue one next-cycle optimization prompt to each non-manager agent and then to manager itself if desired by the operator.",
            "input": [
              "retrospective_summary"
            ],
            "output": [
              "per_agent_optimization_prompts"
            ],
            "notes": [
              "These prompts are meant to be carried into the next cycle.start.",
              "They should be actionable in spirit but should not be frozen into rigid engine semantics."
            ]
          },
          "product.report": {
            "owner": "manager",
            "goal": "Synthesize product-test, benchmark, and cross-cycle evidence into one formal product evaluation report for the current cycle.",
            "input": [
              "product_test_report",
              "benchmark_report",
              "cross_cycle_report"
            ],
            "output": [
              "product_evaluation_report"
            ],
            "notes": [
              "This stage closes the product-evaluation lane before retrospective planning starts.",
              "Manager must reference real testing and benchmark evidence rather than generic conclusions."
            ]
          },
          "agent.self_optimize": {
            "owner": "non_manager_agents_under_manager_collection",
            "goal": "Let each non-manager agent convert retrospective findings into its own next-cycle execution adjustments.",
            "input": [
              "per_agent_optimization_prompts",
              "retrospective_summary"
            ],
            "output": [
              "per_agent_self_optimization_notes"
            ],
            "notes": [
              "This stage is for agent-specific self-improvement notes, not for direct stage advancement.",
              "Manager still remains the only formal transition authority."
            ]
          },
          "optimization.rule.apply": {
            "owner": "manager",
            "goal": "Turn retrospective and self-optimization outputs into explicit next-cycle optimization rules and then reopen the next cycle.",
            "input": [
              "retrospective_summary",
              "per_agent_self_optimization_notes"
            ],
            "output": [
              "applied_optimization_rules"
            ],
            "notes": [
              "This stage closes the current cycle and feeds rules into the next cycle.start.",
              "Applied rules must be explicit enough to be carried forward as next-cycle input."
            ]
          }
        }
      }
    },
    "execution_spec": {
