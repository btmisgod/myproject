      "role_assignments": {
        "manager": {
          "agent_id": "__MANAGER_AGENT_ID__",
          "server_gate_role": "manager",
          "responsibility": "stage organization, watchdog, final decision, formal close"
        },
        "editor": {
          "agent_id": "__EDITOR_AGENT_ID__",
          "server_gate_role": "worker",
          "responsibility": "compose approved content into the product body"
        },
        "tester": {
          "agent_id": "__TESTER_AGENT_ID__",
          "server_gate_role": "worker",
          "responsibility": "first consumer for collect stage and direct reviewer for worker submissions"
        },
        "worker_a": {
          "agent_id": "__WORKER_A_AGENT_ID__",
          "server_gate_role": "worker",
          "responsibility": "collect politics_economy and technology content"
        },
        "worker_b": {
          "agent_id": "__WORKER_B_AGENT_ID__",
          "server_gate_role": "worker",
          "responsibility": "collect sports and entertainment content"
        }
      },
      "role_rules": {
        "manager_holds_decision_authority_for_step_transition": true,
        "manager_has_formal_close_duty_for_every_stage": true,
        "tester_is_first_consumer_for_collect": true,
        "tester_may_directly_issue_pass_partial_pass_redo_to_workers": true,
        "cross_stage_control_must_route_via_manager": true,
        "peer_behavior_must_not_be_scripted_in_code": true,
        "text_first_collaboration": true
      }
    },
    "group_identity": {
      "group_type": "project",
      "workflow_mode": "bootstrap_plus_content_output",
      "group_objective": "Run bootstrap and content-output workflow through group dialogue with server-managed stage gates."
    },
    "workflow": {
      "formal_workflow": {
        "workflow_id": "newsflow-bootstrap-content-cutover-v1",
        "goal": "Pass bootstrap and content-output flow with correct manager contract, tester-first collect consumption, and text-first collaboration.",
        "design_principles": [
          "community_is_the_communication_bus",
          "text_first_collaboration",
          "server_controls_stage_gates_only",
          "manager_only_server_initialized_role",
          "tester_is_first_consumer_for_collect",
          "old_stage_messages_lose_actionability_after_stage_advance"
        ],
        "stages": {
          "step0": {
            "owner": "manager",
            "goal": "Manager establishes the group kickoff surface and explains group goal, role structure, and bootstrap overview.",
            "output": [
              "step0_public_kickoff"
            ]
          },
          "step1": {
            "owner": "non_manager_agents",
            "goal": "Non-manager roles align on task understanding and role boundary.",
            "output": [
              "step1_alignment_response"
            ]
          },
          "step2": {
            "owner": "non_manager_agents",
            "goal": "Non-manager roles confirm readiness and capability for the current group task.",
            "output": [
              "task_ready_or_blocker"
            ]
          },
          "formal_start": {
            "owner": "manager",
            "goal": "Manager formally closes bootstrap and enters the content workflow.",
            "output": [
              "bootstrap_formal_close"
            ]
          },
          "cycle.start": {
            "owner": "manager",
            "goal": "Manager decomposes the cycle task and defines the next-stage goal and acceptance focus.",
            "output": [
              "cycle_task_plan"
            ]
          },
          "material.collect": {
            "owner": "worker_production_tester_first_consumption_manager_final_decision",
            "goal": "Workers submit concrete material in group text; tester directly reviews worker submissions; manager remains mostly silent until final decision or watchdog.",
            "output": [
              "collect_stage_dialogue"
            ],
            "notes": [
              "Worker submissions must be concrete material or concrete blocker, not pure ACK.",
              "Tester directly replies to worker with pass, partial_pass, or redo.",
              "Manager does not act as first-pass reviewer in collect.",
              "Named artifacts are optional aids, not hard workflow gates."
            ]
          },
          "material.review": {
            "owner": "tester_direct_review_loop_with_manager_final_decision",
            "goal": "Tester consolidates review state and manager decides proceed, forced_proceed, pause, fail, resume, or reopen based on tester conclusion.",
            "output": [
              "tester_stage_conclusion",
              "manager_stage_decision"
            ]
          },
          "draft.compose": {
            "owner": "editor",
            "goal": "Editor composes the approved content into the product body in group-visible text.",
            "output": [
              "product_draft"
            ]
          }
        }
      }
    },
